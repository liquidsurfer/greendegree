---
import '../styles/global.css';
import { routes } from '../config/routes.ts';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'green° — cape town. rescued kites, denim, parachutes.' } = Astro.props;
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
---

<!doctype html>
<html lang="en" class={isHome ? '' : 'nav-revealed'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url} />
    <!-- OG / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1280" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />
    <!-- Font preloads -->
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Fraunces-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <slot name="head" />
  </head>
  <body>

    <header class="g-bar" aria-label="primary navigation">
      <div class="g-bar__inner">
        <a href="/" class="g-bar__brand" aria-label="green° — home">green<span class="gn-deg">°</span></a>
        <nav class="g-bar__links" aria-label="primary">
          <a href={routes.ourStory} class="g-bar__link">our story</a>
          <a href={routes.shop} class="g-bar__link">shop</a>
          <a href={routes.articles} class="g-bar__link">articles</a>
          <a href={routes.contact} class="g-bar__link">contact</a>
        </nav>
        <a href={routes.donate} class="g-bar__donate">donate</a>
      </div>
    </header>

    <div class="g-fab-wrap">
      <button class="g-fab" id="g-fab" type="button" aria-label="open menu" aria-expanded="false" aria-controls="g-menu">
        <span class="g-fab__icon" aria-hidden="true">
          <span class="g-fab__bar"></span>
          <span class="g-fab__bar"></span>
          <span class="g-fab__bar"></span>
        </span>
      </button>
    </div>

    <aside class="g-menu" id="g-menu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="site menu">
      <nav class="g-menu__links" aria-label="primary">
        <a href={routes.home} class="g-menu__link" data-close>home</a>
        <a href={routes.ourStory} class="g-menu__link" data-close>our story</a>
        <a href={routes.shop} class="g-menu__link" data-close>shop</a>
        <a href={routes.articles} class="g-menu__link" data-close>articles</a>
        <a href={routes.contact} class="g-menu__link" data-close>contact</a>
      </nav>
      <a href={routes.donate} class="g-menu__cta" data-close>donate →</a>
    </aside>

    <slot />

    <div class="g-scroll-cue" id="g-scroll-cue" aria-hidden="true">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 9l6 6 6-6"/>
      </svg>
    </div>

    <style>
      .g-scroll-cue {
        position: fixed;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 90;
        color: var(--color-ink, #1a1a17);
        opacity: 0;
        transition: opacity 400ms ease;
        pointer-events: none;
        animation: g-cue-bounce 1.6s ease-in-out infinite;
      }
      .g-scroll-cue.g-scroll-cue--visible { opacity: 0.45; }
      @keyframes g-cue-bounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50%       { transform: translateX(-50%) translateY(5px); }
      }
    </style>

    <script is:inline>
    (function () {
      var html = document.documentElement;

      var sentinel = document.getElementById('nav-reveal-sentinel');
      if (sentinel && !html.classList.contains('nav-revealed')) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting || e.boundingClientRect.top < 0) {
              html.classList.add('nav-revealed');
              io.disconnect();
            }
          });
        }, { rootMargin: '0px 0px -10% 0px' });
        io.observe(sentinel);
      } else if (!sentinel && !html.classList.contains('nav-revealed')) {
        html.classList.add('nav-revealed');
      }

      var fab  = document.getElementById('g-fab');
      var menu = document.getElementById('g-menu');
      if (!fab || !menu) return;

      function openMenu() {
        html.classList.add('menu-open');
        menu.setAttribute('aria-hidden', 'false');
        fab.setAttribute('aria-expanded', 'true');
        fab.setAttribute('aria-label', 'close menu');
      }
      function closeMenu() {
        html.classList.remove('menu-open');
        menu.setAttribute('aria-hidden', 'true');
        fab.setAttribute('aria-expanded', 'false');
        fab.setAttribute('aria-label', 'open menu');
      }

      fab.addEventListener('click', function () {
        html.classList.contains('menu-open') ? closeMenu() : openMenu();
      });
      menu.querySelectorAll('[data-close]').forEach(function (a) {
        a.addEventListener('click', closeMenu);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && html.classList.contains('menu-open')) closeMenu();
      });
    })();

    (function () {
      var cue = document.getElementById('g-scroll-cue');
      if (!cue) return;
      function updateCue() {
        var scrolled = window.scrollY;
        var atBottom = scrolled + window.innerHeight >= document.body.scrollHeight - 120;
        var canScroll = document.body.scrollHeight > window.innerHeight + 40;
        if (canScroll && !atBottom) {
          cue.classList.add('g-scroll-cue--visible');
        } else {
          cue.classList.remove('g-scroll-cue--visible');
        }
      }
      updateCue();
      window.addEventListener('scroll', updateCue, { passive: true });
      window.addEventListener('resize', updateCue, { passive: true });
    })();
    </script>

  </body>
</html>
