---
import '../styles/global.css';
import { routes } from '../config/routes.ts';
import { brand } from '../config/brand.ts';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'green° — cape town. sustainability, upcycling and education.' } = Astro.props;
const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: 'green°',
  url: brand.siteUrl,
  logo: `${brand.siteUrl}/favicon.svg`,
  sameAs: [brand.social.instagramHref],
  email: brand.email.anne,
  description: 'Cape Town non-profit upcycling kites, denim and parachutes into bags. 100% of profits supply stationery to primary schools in the Western Cape, South Africa.',
  areaServed: 'ZA',
};
---

<!doctype html>
<html lang="en" class={isHome ? '' : 'nav-revealed'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url} />
    <!-- OG / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1280" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />
    <!-- Font preloads -->
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Fraunces-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body>

    <header class="g-bar" aria-label="primary navigation">
      <div class="g-bar__inner">
        <a href="/" class="g-bar__brand" aria-label="green° — home">green<span class="gn-deg">°</span></a>
        <nav class="g-bar__links" aria-label="primary">
          <a href={routes.ourStory} class="g-bar__link">our story</a>
          <a href={routes.shop} class="g-bar__link">shop</a>
          <a href={routes.about} class="g-bar__link">about</a>
          <a href={routes.contact} class="g-bar__link">contact</a>
        </nav>
        <a href={routes.donate} class="g-bar__donate">donate</a>
      </div>
    </header>

    <div class="g-bot" id="g-bot">
      <button class="g-bot__menu" id="g-bot-menu" type="button" aria-label="open menu" aria-expanded="false" aria-controls="g-menu">
        <span class="g-bot__menu-icon" aria-hidden="true">
          <span class="g-bot__bar"></span>
          <span class="g-bot__bar"></span>
          <span class="g-bot__bar"></span>
        </span>
        <span class="g-bot__menu-label">explore</span>
      </button>
      <a href={routes.donate} class="g-bot__donate">donate →</a>
    </div>

    <aside class="g-menu" id="g-menu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="site menu">
      <nav class="g-menu__links" aria-label="primary">
        <a href={routes.home} class="g-menu__link" data-close>home</a>
        <a href={routes.ourStory} class="g-menu__link" data-close>our story</a>
        <a href={routes.shop} class="g-menu__link" data-close>shop</a>
        <a href={routes.about} class="g-menu__link" data-close>about</a>
        <a href={routes.contact} class="g-menu__link" data-close>contact</a>
      </nav>
      <a href={routes.donate} class="g-menu__cta" data-close>donate →</a>
    </aside>

    <slot />

    <div class="g-scroll-cue" id="g-scroll-cue" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="26" height="26" focusable="false" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 4v15m0 0l-6-6m6 6l6-6"/>
      </svg>
    </div>

    <style>
      .g-scroll-cue {
        position: fixed;
        bottom: 28px;
        right: var(--page-pad, 32px);
        z-index: 50;
        color: var(--color-ink, #1a1a17);
        opacity: 0;
        transition: opacity 400ms ease;
        pointer-events: none;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 10px;
      }
      @media (max-width: 720px) {
        .g-scroll-cue { right: var(--page-pad-mobile, 20px); }
      }
      .g-scroll-cue::before {
        content: "scroll";
        font-family: var(--font-ui, 'Inter', sans-serif);
        font-size: 10px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        opacity: 0.5;
      }
      .g-scroll-cue svg {
        animation: hp-cue 2s cubic-bezier(0.45, 0, 0.55, 1) infinite;
        opacity: 0.65;
      }
      .g-scroll-cue.g-scroll-cue--visible { opacity: 1; }
      @media (prefers-reduced-motion: reduce) {
        .g-scroll-cue svg { animation: none; }
      }
    </style>

    <footer class="hp-foot" id="foot">
      <div class="hp-foot__inner">
        <div class="hp-foot__col">
          <div class="hp-foot__brand">green<span class="gn-deg">°</span></div>
          <p class="hp-foot__blurb">made in cape town from upcycled kites, denim, and parachutes. every bag sold funds a filled pencil case for a child at a western cape primary school.</p>
        </div>
        <div class="hp-foot__col hp-foot__col--nav">
          <nav class="hp-foot__nav" aria-label="footer navigation">
            <a href={routes.ourStory} class="hp-foot__navlink">our story</a>
            <a href={routes.shop} class="hp-foot__navlink">shop</a>
            <a href={routes.about} class="hp-foot__navlink">about</a>
            <a href={routes.articles} class="hp-foot__navlink">articles</a>
            <a href={routes.contact} class="hp-foot__navlink">contact</a>
            <a href={routes.donate} class="hp-foot__navlink">donate</a>
          </nav>
          <button class="hp-foot__top" id="hp-foot-top" type="button" aria-label="scroll to top of page">↑ top</button>
        </div>
      </div>
      <div class="hp-foot__legal">
        <div class="hp-foot__dot" aria-hidden="true"></div>
        <div class="hp-foot__copy">green<span class="gn-deg">°</span> — cape town — founded december 2019.</div>
        <div class="hp-foot__tos-row">
          <a href="/terms" class="hp-foot__tos">terms</a>
          <span class="hp-foot__sep" aria-hidden="true">·</span>
          <a href="/privacy" class="hp-foot__tos">privacy</a>
        </div>
      </div>
    </footer>

    <script is:inline>
    (function () {
      var html = document.documentElement;

      var sentinel = document.getElementById('nav-reveal-sentinel');
      if (sentinel && !html.classList.contains('nav-revealed')) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting || e.boundingClientRect.top < 0) {
              html.classList.add('nav-revealed');
              io.disconnect();
            }
          });
        }, { rootMargin: '0px 0px -10% 0px' });
        io.observe(sentinel);
      } else if (!sentinel && !html.classList.contains('nav-revealed')) {
        html.classList.add('nav-revealed');
      }

      var fab  = document.getElementById('g-bot-menu');
      var menu = document.getElementById('g-menu');
      if (!fab || !menu) return;

      function openMenu() {
        html.classList.add('menu-open');
        menu.setAttribute('aria-hidden', 'false');
        fab.setAttribute('aria-expanded', 'true');
        fab.setAttribute('aria-label', 'close menu');
      }
      function closeMenu() {
        html.classList.remove('menu-open');
        menu.setAttribute('aria-hidden', 'true');
        fab.setAttribute('aria-expanded', 'false');
        fab.setAttribute('aria-label', 'open menu');
      }

      fab.addEventListener('click', function () {
        html.classList.contains('menu-open') ? closeMenu() : openMenu();
      });
      menu.querySelectorAll('[data-close]').forEach(function (a) {
        a.addEventListener('click', closeMenu);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && html.classList.contains('menu-open')) closeMenu();
      });

      var topBtn = document.getElementById('hp-foot-top');
      if (topBtn) {
        topBtn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    })();

    (function () {
      var cue = document.getElementById('g-scroll-cue');
      if (!cue) return;
      var hasHeroScroll = !!document.getElementById('nav-reveal-sentinel');
      function updateCue() {
        var scrolled = window.scrollY;
        var atBottom = scrolled + window.innerHeight >= document.body.scrollHeight - 120;
        var canScroll = document.body.scrollHeight > window.innerHeight + 40;
        var heroCueGone = !hasHeroScroll || document.documentElement.classList.contains('nav-revealed');
        if (canScroll && !atBottom && heroCueGone) {
          cue.classList.add('g-scroll-cue--visible');
        } else {
          cue.classList.remove('g-scroll-cue--visible');
        }
      }
      updateCue();
      window.addEventListener('scroll', updateCue, { passive: true });
      window.addEventListener('resize', updateCue, { passive: true });
    })();
    </script>

  </body>
</html>
