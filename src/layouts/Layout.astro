---
import '../styles/global.css';
import { routes } from '../config/routes.ts';
import { brand } from '../config/brand.ts';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'green° — cape town. sustainability, upcycling and education.' } = Astro.props;
const isHome     = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';
const isDonate   = Astro.url.pathname === '/donate' || Astro.url.pathname === '/donate/';
const isArticles = Astro.url.pathname === '/articles' || Astro.url.pathname === '/articles/';
const isLeaf     = !isHome;

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: 'green°',
  url: brand.siteUrl,
  logo: `${brand.siteUrl}/favicon.svg`,
  sameAs: [brand.social.instagramHref],
  email: brand.email.anne,
  description: 'Cape Town non-profit upcycling kites, denim and parachutes into bags. 100% of profits supply stationery to primary schools in the Western Cape, South Africa.',
  areaServed: 'ZA',
};
---

<!doctype html>
<html lang="en" class={isHome ? '' : 'nav-revealed'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url} />
    <!-- OG / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/og-image.jpg" />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1280" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-image.jpg" />
    <!-- Font preloads -->
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Fraunces-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <style>.g-menu { transform: translateX(-100%); }</style>
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body>

    <header class="g-bar" aria-label="primary navigation">
      <div class="g-bar__inner">
        <a href="/" class="g-bar__brand" aria-label="green° — home">green<span class="gn-deg">°</span></a>
        <nav class="g-bar__links" aria-label="primary">
          <a href={routes.impact} class="g-bar__link">impact</a>
          <a href={routes.ourStory} class="g-bar__link">our story</a>
          <a href={routes.shop} class="g-bar__link">shop</a>
          <a href={routes.contact} class="g-bar__link">contact</a>
        </nav>
        <a href={routes.donate} class="g-bar__donate">donate</a>
      </div>
    </header>

    {!isDonate && (
      <a href={routes.donate} class="g-fab g-fab--donate" aria-label="donate">donate →</a>
    )}

    {isDonate ? (
      <button class="g-fab g-fab--menu" type="button" aria-label="go back" onclick="goBack()">
        <span class="g-fab__back" aria-hidden="true">←</span>
      </button>
    ) : (
      <button
        class="g-fab g-fab--menu"
        id="g-bot-menu"
        type="button"
        aria-label="open menu"
        aria-expanded="false"
        aria-controls="g-menu"
      >
        <span class="g-fab__icon" aria-hidden="true">
          <span class="g-fab__bar"></span>
          <span class="g-fab__bar"></span>
          <span class="g-fab__bar"></span>
        </span>
      </button>
    )}

    <aside class="g-menu" id="g-menu" aria-hidden="true" role="dialog" aria-modal="true" aria-label="site menu">
      <nav class="g-menu__links" aria-label="primary">
        <a href={routes.home} class="g-menu__link" data-close>home</a>
        <a href={routes.impact} class="g-menu__link" data-close>impact</a>
        <a href={routes.ourStory} class="g-menu__link" data-close>our story</a>
        <a href={routes.shop} class="g-menu__link" data-close>shop</a>
        <a href={routes.contact} class="g-menu__link" data-close>contact</a>
      </nav>
    </aside>

    <slot />

    <footer class="hp-foot" id="foot">
      <div class="hp-foot__inner">
        <div class="hp-foot__col">
          <div class="hp-foot__brand">green<span class="gn-deg">°</span></div>
          <p class="hp-foot__blurb">made in cape town from upcycled kites, denim, and parachutes. every bag sold funds a filled pencil case for a child at a western cape primary school.</p>
        </div>
        <div class="hp-foot__col hp-foot__col--nav">
          {isArticles
            ? <button class="hp-foot__press hp-foot__press--back" type="button" onclick="goBack()">← back</button>
            : <a href={routes.articles} class="hp-foot__press">in the headlines</a>
          }
          <a href="https://www.instagram.com/greendegree_/" class="hp-foot__press" target="_blank" rel="noopener noreferrer">instagram</a>
          <a href={routes.contact} class="hp-foot__press">contact us</a>
        </div>
      </div>
      <div class="hp-foot__legal">
        <div class="hp-foot__dot" aria-hidden="true"></div>
        <div class="hp-foot__copy">green<span class="gn-deg">°</span> — cape town — founded december 2019.</div>
        <div class="hp-foot__tos-row">
          <a href="/terms" class="hp-foot__tos">terms</a>
          <span class="hp-foot__sep" aria-hidden="true">·</span>
          <a href="/privacy" class="hp-foot__tos">privacy</a>
        </div>
      </div>
    </footer>

    <script is:inline>
    function goBack() {
      document.body.style.transition = 'opacity 110ms ease';
      document.body.style.opacity = '0';
      setTimeout(function () {
        history.length > 1 ? history.back() : (window.location.href = '/');
      }, 110);
    }

    (function () {
      var html = document.documentElement;

      var sentinel = document.getElementById('nav-reveal-sentinel');
      if (sentinel && !html.classList.contains('nav-revealed')) {
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting || e.boundingClientRect.top < 0) {
              html.classList.add('nav-revealed');
              io.disconnect();
            }
          });
        }, { rootMargin: '0px 0px -10% 0px' });
        io.observe(sentinel);
      } else if (!sentinel && !html.classList.contains('nav-revealed')) {
        html.classList.add('nav-revealed');
      }

      var fab  = document.getElementById('g-bot-menu');
      var menu = document.getElementById('g-menu');
      if (!fab || !menu) return;

      var closingTimer = null;

      function openMenu() {
        if (closingTimer) { clearTimeout(closingTimer); closingTimer = null; }
        html.classList.remove('menu-closing');
        html.classList.add('menu-open');
        menu.setAttribute('aria-hidden', 'false');
        fab.setAttribute('aria-expanded', 'true');
        fab.setAttribute('aria-label', 'close menu');
      }
      function closeMenu() {
        html.classList.remove('menu-open');
        html.classList.add('menu-closing');
        closingTimer = setTimeout(function () {
          html.classList.remove('menu-closing');
          closingTimer = null;
        }, 360);
        menu.setAttribute('aria-hidden', 'true');
        fab.setAttribute('aria-expanded', 'false');
        fab.setAttribute('aria-label', 'open menu');
      }

      fab.addEventListener('click', function () {
        html.classList.contains('menu-open') ? closeMenu() : openMenu();
      });
      menu.querySelectorAll('[data-close]').forEach(function (a) {
        a.addEventListener('click', function () {
          if (a.getAttribute('href') === '/') sessionStorage.setItem('gd-skip-intro', '1');
          closeMenu();
        });
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && html.classList.contains('menu-open')) closeMenu();
      });

      /* any brand-logo click sets the skip flag so home lands zoomed in */
      var brand = document.querySelector('.g-bar__brand');
      if (brand) brand.addEventListener('click', function () {
        sessionStorage.setItem('gd-skip-intro', '1');
      });

    })();
    </script>

  </body>
</html>
