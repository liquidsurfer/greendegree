---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { routes } from '../config/routes.ts';
import imgHowCollect  from '../assets/images/how-01-collect.avif';
import imgHowCreate   from '../assets/images/how-02-create.jpg';
import imgHowContrib  from '../assets/images/how-03-contribute.jpg';
import imgTangibility from '../assets/images/10-tangibility-flatlay.jpg';
---

<Layout
  title="about — green°"
  description="how green° works — the process, the schools we support, and what every bag sale means for a child."
>

<header class="ab-head">
  <div class="ab-head__inner">
    <span class="gn-eyebrow">about green°</span>
    <h1 class="ab-head__title">how it works.</h1>
    <p class="ab-head__sub">we collect donated materials, create unique bags, and put 100% of profits into pencil cases and stationery for three cape town schools.</p>
  </div>
</header>

<!-- PROCESS -->
<section class="hp-how" id="process">
  <div class="hp-how__head">
    <span class="gn-eyebrow">the process</span>
    <h2 class="hp-how__title">collect, create, contribute.</h2>
  </div>
  <div class="hp-how__steps">
    <article class="hp-how__step">
      <div class="hp-how__num">01</div>
      <div class="hp-how__img-wrap">
        <Image class="hp-how__img" src={imgHowCollect} alt="a pile of donated denim, waiting to be sorted" width={800} format="webp" />
      </div>
      <h3 class="hp-how__step-title">donated kites, paragliders and denims</h3>
      <p class="hp-how__step-line">upcycle — transform waste.</p>
    </article>
    <article class="hp-how__step">
      <div class="hp-how__num">02</div>
      <div class="hp-how__img-wrap">
        <Image class="hp-how__img" src={imgHowCreate} alt="an artisan's hands laying out bright kite sail ready for cutting" width={800} format="webp" />
      </div>
      <h3 class="hp-how__step-title">hand-made unique lifestyle products</h3>
      <p class="hp-how__step-line">create employment.<br>upskill people.</p>
    </article>
    <article class="hp-how__step">
      <div class="hp-how__num">03</div>
      <div class="hp-how__img-wrap">
        <Image class="hp-how__img" src={imgHowContrib} alt="children at a western cape primary holding up denim pencil cases" width={800} format="webp" />
      </div>
      <h3 class="hp-how__step-title">2,500 children each year</h3>
      <p class="hp-how__step-line">support 3 schools with stationery every year.<br>contribute to local economy.</p>
    </article>
  </div>
</section>

<!-- SCHOOLS -->
<section class="hp-schools" id="schools">
  <div class="hp-schools__inner">
    <div class="hp-schools__head">
      <span class="gn-eyebrow">the schools</span>
      <h2 class="hp-schools__title">three schools.<br>one cape town.</h2>
    </div>
    <div class="hp-schools__list">
      <div class="hp-schools__school">
        <div class="hp-schools__num">01</div>
        <div class="hp-schools__name">Capricorn Primary</div>
        <div class="hp-schools__loc">Capricorn, Western Cape</div>
      </div>
      <div class="hp-schools__school">
        <div class="hp-schools__num">02</div>
        <div class="hp-schools__name">Caravelle Primary</div>
        <div class="hp-schools__loc">Strandfontein</div>
      </div>
      <div class="hp-schools__school">
        <div class="hp-schools__num">03</div>
        <div class="hp-schools__name">Westlake Primary</div>
        <div class="hp-schools__loc">Westlake, Southern Suburbs</div>
      </div>
    </div>
  </div>
</section>

<!-- TANGIBILITY -->
<section class="hp-tangibility" id="one-set">
  <div class="hp-tangibility__inner">
    <div class="hp-tangibility__text">
      <span class="gn-eyebrow hp-reveal">what "one set" means</span>
      <h3 class="hp-tangibility__title hp-reveal hp-reveal--delay-1">a denim pencil case, one set of stationery, for the year</h3>
      <p class="hp-tangibility__body hp-reveal hp-reveal--delay-2">we take profits from sales, and fill pencil cases.</p>
      <ul class="hp-kit-list">
        <li>1 denim pencil case</li>
        <li>colouring crayons</li>
        <li>pens</li>
        <li>pencils</li>
        <li>erasers</li>
        <li>sharpener</li>
      </ul>
    </div>
    <div class="hp-tangibility__img-wrap hp-reveal hp-reveal--delay-1">
      <Image class="hp-tangibility__img" src={imgTangibility} alt="flatlay of denim pencil cases with pencils, erasers and exercise books" width={1000} format="webp" />
    </div>
  </div>
</section>

<!-- COUNTERS -->
<section class="hp-counters" id="impact">
  <div class="hp-counters__inner">
    <div class="hp-counters__grid">
      <article class="hp-counter">
        <span class="hp-counter__num" data-target="12810" data-duration="2200">0</span>
        <span class="hp-counter__label">pencil cases delivered</span>
      </article>
      <article class="hp-counter">
        <span class="hp-counter__num" data-target="1083" data-duration="1800">0</span>
        <span class="hp-counter__label">pairs of denim jeans upcycled</span>
      </article>
      <article class="hp-counter">
        <span class="hp-counter__num" data-target="151" data-duration="1400">0</span>
        <span class="hp-counter__label">kites given a second life</span>
      </article>
    </div>
    <p class="hp-counters__stamp">as of 2026 · cape town</p>
  </div>
</section>

</Layout>

<style is:global>
/* ---- About page header ---- */
.ab-head {
  background: var(--color-bg-tint);
  padding: 120px var(--page-pad) 96px;
  border-bottom: 1px solid var(--color-rule);
}
.ab-head__inner {
  max-width: var(--page-max);
  margin: 0 auto;
  display: grid;
  gap: 24px;
  max-width: 720px;
}
.ab-head__title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(3rem, 7vw, 6rem);
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  margin: 0;
}
.ab-head__sub {
  font-family: var(--font-ui);
  font-size: 16px;
  line-height: 1.65;
  color: var(--color-ink-soft);
  margin: 0;
  max-width: 52ch;
}
@media (max-width: 820px) {
  .ab-head { padding: 80px var(--page-pad-mobile) 64px; }
}

/* ---- Schools ---- */
.hp-schools {
  background: var(--color-bg-tint);
  padding: 96px 0;
}
.hp-schools__inner {
  max-width: var(--page-max);
  margin: 0 auto;
  padding-inline: var(--page-pad);
  display: grid;
  gap: 64px;
}
.hp-schools__head { display: grid; gap: 16px; max-width: 520px; }
.hp-schools__title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(2rem, 4.5vw, 4rem);
  line-height: 1.05;
  letter-spacing: -0.028em;
  color: var(--color-ink);
  margin: 0;
}
.hp-schools__list {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: 1px solid var(--color-rule);
}
.hp-schools__school {
  padding: 32px 32px 32px 0;
  margin-right: 32px;
  border-right: 1px solid var(--color-rule);
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.hp-schools__school:last-child { border-right: 0; padding-right: 0; margin-right: 0; }
.hp-schools__num {
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 300;
  font-size: 14px;
  color: var(--color-sage-deep);
  letter-spacing: 0.06em;
}
.hp-schools__name {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(1.25rem, 2vw, 1.625rem);
  letter-spacing: -0.015em;
  color: var(--color-ink);
  line-height: 1.15;
}
.hp-schools__loc {
  font-family: var(--font-ui);
  font-size: 13px;
  color: var(--color-ink-faint);
  letter-spacing: 0.02em;
}
@media (max-width: 820px) {
  .hp-schools { padding: 64px 0; }
  .hp-schools__inner { padding-inline: var(--page-pad-mobile); gap: 40px; }
  .hp-schools__list { grid-template-columns: 1fr; }
  .hp-schools__school {
    border-right: 0;
    padding-right: 0;
    margin-right: 0;
    border-bottom: 1px solid var(--color-rule);
  }
  .hp-schools__school:last-child { border-bottom: 0; }
}
</style>

<script is:inline>
/* Section fade-in reveals */
(function () {
  var els = document.querySelectorAll('.hp-reveal');
  if (!els.length) return;
  if (!('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('is-visible'); });
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0, rootMargin: '0px 0px -40px 0px' });
  els.forEach(function (el) { io.observe(el); });
})();

/* Counter animation */
(function () {
  var nodes = document.querySelectorAll('.hp-counter__num');
  function ease(t) { return 1 - Math.pow(1 - t, 3); }
  function animate(el) {
    if (el.dataset.animated) return;
    el.dataset.animated = '1';
    var target   = parseInt(el.dataset.target, 10) || 0;
    var duration = parseInt(el.dataset.duration, 10) || 1800;
    var start = null;
    function frame(ts) {
      if (start === null) start = ts;
      var t = Math.min(1, (ts - start) / duration);
      el.textContent = Math.round(target * ease(t)).toLocaleString('en-US');
      if (t < 1) requestAnimationFrame(frame);
      else el.textContent = target.toLocaleString('en-US');
    }
    requestAnimationFrame(frame);
  }
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { animate(e.target); io.unobserve(e.target); }
      });
    }, { threshold: 0.35 });
    nodes.forEach(function (n) { io.observe(n); });
  } else {
    nodes.forEach(animate);
  }
})();
</script>
