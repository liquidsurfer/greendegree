---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page not found — green°">
  <div class="not-found">
    <div class="not-found__inner">
      <div class="not-found__num">404</div>
      <h1 class="not-found__heading">this page doesn't exist<span class="gn-deg">.</span></h1>
      <p class="not-found__body">it may have moved, or the link might be wrong.</p>
      <div class="not-found__links">
        <a href="/" class="not-found__link">go home →</a>
        <a href="/our-story" class="not-found__link">our story →</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px var(--page-pad-mobile);
    background: var(--color-bg);
  }
  .not-found__inner {
    max-width: 560px;
    width: 100%;
  }
  .not-found__num {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(6rem, 20vw, 14rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: var(--color-rule);
    margin-bottom: 32px;
  }
  .not-found__heading {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.025em;
    color: var(--color-ink);
    margin: 0 0 20px;
  }
  .not-found__body {
    font-family: var(--font-ui);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin: 0 0 40px;
  }
  .not-found__links {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }
  .not-found__link {
    font-family: var(--font-ui);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 2px;
    transition: border-color 160ms, color 160ms;
  }
  .not-found__link:hover {
    color: var(--color-sage-deep);
    border-color: var(--color-sage-deep);
  }
</style>
