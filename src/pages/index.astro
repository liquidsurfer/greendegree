@media (max-width: 720px) {
  .hp-transition { height: 100svh; min-height: 0; max-height: none; }
  .hp-transition__text { padding-inline: var(--page-pad-mobile); bottom: 40px; }
}

/* ============================================================
   COLLECTIONS — mobile responsive (tiles stack via global.css)
   ============================================================ */
@media (max-width: 820px) {
  .hp-collections__head { flex-wrap: wrap; gap: 16px; }
}

/* ============================================================
   PRESS BAR
