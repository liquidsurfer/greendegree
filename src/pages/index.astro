}
.hp-press__pubs { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
.hp-press__pub {
  font-family: var(--font-display); font-weight: 300;
  font-size: clamp(0.9rem, 1.6vw, 1.25rem);
  letter-spacing: -0.01em; color: var(--color-ink-soft);
