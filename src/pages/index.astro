---
import Layout from '../layouts/Layout.astro';
import { Image, getImage } from 'astro:assets';
import imgHero        from '../assets/images/why-capricorn-primary.jpg';
import imgHowCollect  from '../assets/images/how-01-collect.avif';
import imgHowCreate   from '../assets/images/how-02-create.jpg';
import imgHowContrib  from '../assets/images/how-03-contribute.jpg';
import imgTangibility from '../assets/images/10-tangibility-flatlay.jpg';
import imgTransition  from '../assets/images/01-kite-cederberg.jpg';
import imgKiteTrio    from '../assets/images/02b-hero-kite-trio.jpg';
import imgDenim       from '../assets/images/04-collection-denim.jpg';
import imgParachute   from '../assets/images/14-parachute-tote.jpeg';
import imgFounders    from '../assets/images/12-founders.jpg';
import imgClassroom   from '../assets/images/classroom-pencil-cases-sepia.jpg';

const heroPreload = await getImage({ src: imgHero, format: 'webp', width: 1920 });
---

<Layout title="green° — cape town. rescued kites, denim, parachutes.">
  <link slot="head" rel="preload" href={heroPreload.src} as="image" type="image/webp" />

<!-- LOADER -->
<div class="gd-loader" id="gd-loader">
  <div class="gd-loader__brand">green<span class="gn-deg">°</span></div>
  <div class="gd-loader__rule"></div>
</div>

<!-- BEAT 1 — Hero journey -->
<div class="hp-hero-outer" id="hero-outer">
  <section class="hp-hero">
    <Image class="hp-hero__img" src={imgHero} alt="children at capricorn primary holding up green° denim pencil cases" width={1920} loading="eager" format="webp" />
    <div class="hp-hero__overlay"></div>
    <div class="hp-hero__text">
      <div>
        <div class="hp-hero__eyebrow">capricorn primary · 26 january 2023</div>
        <h1 class="hp-hero__title">creatively crafting change<span class="gn-deg">.</span></h1>
      </div>
      <div class="hp-hero__scroll-cue" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="26" height="26" focusable="false">
          <path d="M12 4v15m0 0l-6-6m6 6l6-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
    </div>
  </section>
</div>

<!-- Reveals the global nav as we enter BEAT 1.5 -->
<div id="nav-reveal-sentinel" aria-hidden="true"></div>

<!-- BEAT 1.5 — THE INTERACTIVE SENTENCE -->
<section class="hp-diagram-outer" id="diagram">
  <div class="hp-diagram-sticky">

    <div class="hp-diagram-eye">
      <span class="gn-eyebrow">the why · the how · the what</span>
    </div>


    <div class="hp-diagram-stage">

      <div class="hp-diagram-group hp-diagram-group--left" id="dgrp-sustainably" aria-label="sustainably — what it means">
        <div class="hp-diagram-group-label">sustainably</div>
        <div class="hp-diagram-node" style="transition-delay:0ms">recycle</div>
        <div class="hp-diagram-node" style="transition-delay:60ms">create employment</div>
        <div class="hp-diagram-node" style="transition-delay:120ms">up-skill local artisans</div>
        <div class="hp-diagram-node" style="transition-delay:180ms">save materials from landfill</div>
        <div class="hp-diagram-node" style="transition-delay:240ms">create unique lifestyle products from old fabrics</div>
        <div class="hp-diagram-node" style="transition-delay:300ms">create awareness of the ecological crisis</div>
      </div>

      <div class="hp-diagram-center">
        <p class="hp-diagram-sentence">
          <span class="hp-word" id="word-we">we</span>
          <button class="hp-diagram-kw hp-word" id="dkw-sustainably" data-group="sustainably">sustainably</button>
          <button class="hp-diagram-kw hp-word" id="dkw-raise-funds" data-group="raise-funds">raise funds</button>
          <button class="hp-diagram-kw hp-word" id="dkw-education" data-group="education">for education</button>
          <span class="hp-word" id="word-insa">in SA<span class="gn-deg">.</span></span>
        </p>
        <div class="hp-diagram-hint" id="diagram-hint">hover to explore</div>
      </div>

      <div class="hp-diagram-group hp-diagram-group--right" id="dgrp-raise-funds" aria-label="raise funds — how it works">
        <div class="hp-diagram-group-label">raise funds</div>
        <div class="hp-diagram-node" style="transition-delay:0ms">sales of bags fund stationery packs</div>
        <div class="hp-diagram-node" style="transition-delay:80ms">100% of profits reach the children directly</div>
      </div>

      <div class="hp-diagram-group hp-diagram-group--bottom" id="dgrp-education" aria-label="education — the impact">
        <div class="hp-diagram-group-label" style="text-align:center">education</div>
        <div class="hp-diagram-node" style="transition-delay:0ms">
          <span class="hp-diagram-node__num">3</span>
          schools receive pencil cases &amp; stationery every year
        </div>
        <div class="hp-diagram-node" style="transition-delay:100ms">
          <span class="hp-diagram-node__num">2,500</span>
          children supported annually
        </div>
      </div>

    </div>

    <div class="hp-diagram-dots" aria-hidden="true">
      <div class="hp-diagram-dot" data-phase="1"></div>
      <div class="hp-diagram-dot" data-phase="2"></div>
      <div class="hp-diagram-dot" data-phase="3"></div>
    </div>

    <div class="hp-diagram-progress-wrap">
      <div class="hp-diagram-progress-bar" id="diagram-bar"></div>
    </div>

    <!-- MOBILE SENTENCE -->
    <div class="hp-diagram-mobile" aria-hidden="false">
      <div class="hp-mob-sentence-wrap">
        <p class="hp-mob-sentence-text">
          <span class="hp-mob-word" id="mob-we">we</span>
          <span class="hp-mob-word hp-mob-kw" id="mob-sustainably">sustainably</span>
          <span class="hp-mob-word hp-mob-kw" id="mob-raise-funds">raise funds</span>
          <span class="hp-mob-word hp-mob-kw" id="mob-education">for education</span>
          <span class="hp-mob-word" id="mob-insa">in SA<span class="gn-deg">.</span></span>
        </p>
      </div>
      <div class="hp-mob-branch-area">
        <div class="hp-mob-branch" id="mob-branch-s">
          <div class="hp-mob-branch-label">sustainably</div>
          <div class="hp-mob-leaf">recycle</div>
          <div class="hp-mob-leaf">create employment</div>
          <div class="hp-mob-leaf">up-skill local artisans</div>
          <div class="hp-mob-leaf">save materials from landfill</div>
          <div class="hp-mob-leaf">create unique lifestyle products from old fabrics</div>
          <div class="hp-mob-leaf">create awareness of the ecological crisis</div>
        </div>
        <div class="hp-mob-branch" id="mob-branch-r">
          <div class="hp-mob-branch-label">raise funds</div>
          <div class="hp-mob-leaf">sales of bags fund stationery packs</div>
          <div class="hp-mob-leaf">100% of profits reach the children directly</div>
        </div>
        <div class="hp-mob-branch" id="mob-branch-e">
          <div class="hp-mob-branch-label">for education</div>
          <div class="hp-mob-leaf"><span class="hp-mob-stat">3</span>schools receive pencil cases &amp; stationery every year</div>
          <div class="hp-mob-leaf"><span class="hp-mob-stat">2,500</span>children supported annually</div>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- BEAT 2 — HOW -->
<div class="hp-journey hp-journey--how" id="journey-how" data-journey-cards="3">
  <div class="hp-journey__sticky">
    <section class="hp-how" id="how">
      <div class="hp-how__head">
        <span class="gn-eyebrow">the process</span>
        <h2 class="hp-how__title">collect, create, contribute.</h2>
      </div>
      <div class="hp-how__steps" id="how-track">
        <article class="hp-how__step">
          <div class="hp-how__num">01</div>
          <div class="hp-how__img-wrap">
            <Image class="hp-how__img" src={imgHowCollect} alt="a pile of donated denim, waiting to be sorted" width={800} format="webp" />
          </div>
          <h3 class="hp-how__step-title">donated kites, paragliders and denims</h3>
          <p class="hp-how__step-line">upcycle — transform waste.</p>
        </article>
        <article class="hp-how__step">
          <div class="hp-how__num">02</div>
          <div class="hp-how__img-wrap">
            <Image class="hp-how__img" src={imgHowCreate} alt="an artisan's hands laying out bright kite sail ready for cutting" width={800} format="webp" />
          </div>
          <h3 class="hp-how__step-title">hand-made unique lifestyle products</h3>
          <p class="hp-how__step-line">create employment.<br>upskill people.</p>
        </article>
        <article class="hp-how__step">
          <div class="hp-how__num">03</div>
          <div class="hp-how__img-wrap">
            <Image class="hp-how__img" src={imgHowContrib} alt="children at a cape flats primary holding up denim pencil cases" width={800} format="webp" />
          </div>
          <h3 class="hp-how__step-title">2,500 children each year</h3>
          <p class="hp-how__step-line">support 3 schools with stationery every year.<br>contribute to local economy.</p>
        </article>
      </div>
      <div class="hp-journey__dots" aria-hidden="true">
        <div class="hp-journey__dot is-active"></div>
        <div class="hp-journey__dot"></div>
        <div class="hp-journey__dot"></div>
      </div>
    </section>
  </div>
</div>

<!-- IMPACT JOURNEY: schools → tangibility -->
<div class="hp-journey hp-journey--impact" id="journey-impact" data-journey-cards="2">
  <div class="hp-journey__sticky">
    <div class="hp-impact-track" id="impact-track" style="display:flex;flex-direction:row;height:100%;will-change:transform;">
      <section class="hp-schools">
        <div class="hp-schools__inner">
          <div class="hp-schools__head">
            <span class="gn-eyebrow">the schools</span>
            <h2 class="hp-schools__title">three schools.<br>one cape town.</h2>
          </div>
          <div class="hp-schools__list">
            <div class="hp-schools__school">
              <div class="hp-schools__num">01</div>
              <div class="hp-schools__name">Capricorn Primary</div>
              <div class="hp-schools__loc">Capricorn, Cape Flats</div>
            </div>
            <div class="hp-schools__school">
              <div class="hp-schools__num">02</div>
              <div class="hp-schools__name">Caravelle Primary</div>
              <div class="hp-schools__loc">Strandfontein</div>
            </div>
            <div class="hp-schools__school">
              <div class="hp-schools__num">03</div>
              <div class="hp-schools__name">Westlake Primary</div>
              <div class="hp-schools__loc">Westlake, Southern Suburbs</div>
            </div>
          </div>
        </div>
      </section>
      <section class="hp-tangibility">
        <div class="hp-tangibility__inner">
          <div class="hp-tangibility__text">
            <span class="gn-eyebrow hp-reveal">what "one set" means</span>
            <h3 class="hp-tangibility__title hp-reveal hp-reveal--delay-1">a denim pencil case, one set of stationery, for the year</h3>
            <p class="hp-tangibility__body hp-reveal hp-reveal--delay-2">we take profits from sales, and fill pencil cases.</p>
            <ul class="hp-kit-list">
              <li>1 denim pencil case</li>
              <li>colouring crayons</li>
              <li>pens</li>
              <li>pencils</li>
              <li>erasers</li>
              <li>sharpener</li>
            </ul>
          </div>
          <div class="hp-tangibility__img-wrap hp-reveal hp-reveal--delay-1">
            <Image class="hp-tangibility__img" src={imgTangibility} alt="flatlay of denim pencil cases with pencils, erasers and exercise books" width={1000} format="webp" />
          </div>
        </div>
      </section>
    </div>
    <div class="hp-journey__dots hp-m-only" aria-hidden="true">
      <div class="hp-journey__dot is-active"></div>
      <div class="hp-journey__dot"></div>
    </div>
  </div>
</div>

<!-- LIME UNIT MOMENT -->
<div class="hp-unit-outer" id="unit-outer">
  <section class="hp-unit-lime">
    <div class="hp-unit-fill" id="unit-fill"></div>
    <div class="hp-unit-lime__inner">
      <p class="hp-unit-lime__line">every bag sold<span class="hp-unit-lime__eq">→</span>fills pencil cases.</p>
      <p class="hp-unit-lime__sub">over 12,800+ pencil cases handed out since december 2019.</p>
      <a href="/donate" class="hp-unit-lime__cta">donate →</a>
    </div>
  </section>
</div>

<!-- TRANSITION -->
<section class="hp-transition" aria-hidden="false">
  <Image class="hp-transition__img" src={imgTransition} alt="man carrying an orange kite bag through the Cederberg" width={1920} format="webp" />
  <div class="hp-transition__scrim"></div>
  <div class="hp-transition__text">
    <div class="hp-transition__sub">the collections</div>
    <p class="hp-transition__headline">fun, funky, and functional.</p>
  </div>
</section>

<!-- BEAT 3 — COLLECTIONS -->
<div class="hp-journey hp-journey--collections" id="journey-collections" data-journey-cards="3">
  <div class="hp-journey__sticky">
    <section class="hp-collections" id="collections">
      <div class="hp-collections__head">
        <div>
          <h2 class="hp-collections__title">three collections.</h2>
          <p class="hp-collections__intro">kites become beach bags. denim becomes jackets. parachutes become hand bags.</p>
        </div>
        <a href="/coming-soon" class="hp-collections__shop">shop</a>
      </div>
      <div class="hp-tiles" id="collections-track">
        <a class="hp-tile" href="/coming-soon">
          <div class="hp-tile__img-wrap">
            <Image class="hp-tile__img" src={imgKiteTrio} alt="three kite-fabric cooler bags in orange, pink and blue" width={1200} format="webp" />
          </div>
          <div class="hp-tile__name">kite collection</div>
          <div class="hp-tile__meta">beach bags, coolers, and smaller carry — cut and stitched from recycled kitesurfing sails.</div>
          <div class="hp-tile__price">beach bags R 750  ·  coolers R 1,000  ·  smaller R 350–500</div>
        </a>
        <a class="hp-tile" href="/coming-soon">
          <div class="hp-tile__img-wrap">
            <Image class="hp-tile__img" src={imgDenim} alt="patched denim jacket — close up on buttons and lining" width={1200} format="webp" />
          </div>
          <div class="hp-tile__name">denim collection</div>
          <div class="hp-tile__meta">one-of-a-kind patched jackets, cut from donated jeans. no two alike.</div>
          <div class="hp-tile__price">R 2,000–3,500</div>
        </a>
        <a class="hp-tile" href="/coming-soon">
          <div class="hp-tile__img-wrap">
            <Image class="hp-tile__img" src={imgParachute} alt="crocheted tote made from strips of recycled plastic — yellow, green, blue and white" width={1200} format="webp" />
          </div>
          <div class="hp-tile__name">parachute collection</div>
          <div class="hp-tile__meta">moon bags and space bags from donated parachutes — crocheted and stitched in the workshop.</div>
          <div class="hp-tile__price">moon bags R 500  ·  space bags R 2,500</div>
        </a>
      </div>
      <div class="hp-journey__dots" aria-hidden="true">
        <div class="hp-journey__dot is-active"></div>
        <div class="hp-journey__dot"></div>
        <div class="hp-journey__dot"></div>
      </div>
    </section>
  </div>
</div>

<!-- FOUNDERS -->
<div class="hp-journey hp-journey--founders" id="founders" data-journey-cards="2">
  <div class="hp-journey__sticky">
    <section class="hp-founders" id="founders-track">
      <div class="hp-founders__img-wrap hp-reveal">
        <Image class="hp-founders__img" src={imgFounders} alt="anne and cheryl, each holding armfuls of denim pieces mid-sort" width={800} format="webp" />
      </div>
      <div class="hp-founders__text">
        <span class="gn-eyebrow hp-reveal hp-reveal--delay-1">a note from the founders</span>
        <p class="hp-founders__origin">
          we had our first fundraising function, a small gathering of friends and family where we collected old denim and raised R12,000 in the form of pencil case sponsorship — and so began a creative, challenging and uplifting journey.
        </p>
        <h3 class="hp-founders__title">we'd never be able to do this without our families, friends, and the community — those who donate, purchase, support and collaborate.</h3>
        <div class="hp-founders__sig">anne &amp; cheryl · cape town · december 2019</div>
      </div>
      <div class="hp-journey__dots hp-m-only" aria-hidden="true">
        <div class="hp-journey__dot is-active"></div>
        <div class="hp-journey__dot"></div>
      </div>
    </section>
  </div>
</div>

<!-- COUNTERS -->
<section class="hp-counters">
  <div class="hp-counters__inner">
    <div class="hp-counters__grid">
      <article class="hp-counter">
        <span class="hp-counter__num" data-target="12810" data-duration="2200">0</span>
        <span class="hp-counter__label">pencil cases delivered</span>
      </article>
      <article class="hp-counter">
        <span class="hp-counter__num" data-target="1083" data-duration="1800">0</span>
        <span class="hp-counter__label">pairs of denim jeans rescued</span>
      </article>
      <article class="hp-counter">
        <span class="hp-counter__num" data-target="151" data-duration="1400">0</span>
        <span class="hp-counter__label">kites given a second life</span>
      </article>
    </div>
    <p class="hp-counters__stamp">as of 2026 · cape town</p>
  </div>
</section>

<!-- INVITE -->
<div class="hp-journey hp-journey--invite" id="journey-invite" data-journey-cards="2">
  <div class="hp-journey__sticky">
    <section class="hp-invite hp-invite--photo" id="mission">
      <Image class="hp-invite__bg hp-d-only" src={imgClassroom} alt="children in a classroom holding up green° denim pencil cases" width={1920} format="webp" />
      <div class="hp-invite__scrim hp-d-only"></div>
      <div class="hp-invite__inner hp-d-only">
        <span class="gn-eyebrow hp-invite__eyebrow" style="color:rgba(232,225,203,0.72)">the invitation</span>
        <blockquote class="hp-invite__quote">
          we invite everyone to please join us, and become part of the green<span class="gn-deg">°</span> story.
        </blockquote>
        <div class="hp-invite__cta-row">
          <a class="hp-invite__cta" href="/donate">donate</a>
          <a class="hp-invite__cta hp-invite__cta--ghost" href="#collections">shop</a>
        </div>
      </div>
      <div class="hp-invite-track hp-m-only" id="invite-track">
        <div class="hp-invite-card hp-invite-card--photo">
          <Image src={imgClassroom} alt="children in a classroom holding up green° denim pencil cases" width={1200} format="webp" />
        </div>
        <div class="hp-invite-card hp-invite-card--text">
          <span class="gn-eyebrow">the invitation</span>
          <blockquote class="hp-invite__quote">
            we invite everyone to please join us, and become part of the green<span class="gn-deg">°</span> story.
          </blockquote>
          <div class="hp-invite__cta-row">
            <a class="hp-invite__cta" href="/donate">donate</a>
            <a class="hp-invite__cta hp-invite__cta--ghost" href="#collections">shop</a>
          </div>
        </div>
      </div>
      <div class="hp-journey__dots hp-m-only" aria-hidden="true">
        <div class="hp-journey__dot is-active"></div>
        <div class="hp-journey__dot"></div>
      </div>
    </section>
  </div>
</div>

<!-- PRESS BAR -->
<section class="hp-press">
  <div class="hp-press__inner">
    <span class="hp-press__label">as featured in</span>
    <div class="hp-press__pubs">
      <a href="/articles" class="hp-press__pub">Green Economy Media</a>
      <span class="hp-press__sep" aria-hidden="true">·</span>
      <a href="/articles" class="hp-press__pub">Good Things Guy</a>
      <span class="hp-press__sep" aria-hidden="true">·</span>
      <a href="/articles" class="hp-press__pub">Twyg</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer class="hp-foot" id="foot">
  <div class="hp-foot__inner">
    <div class="hp-foot__col">
      <div class="hp-foot__brand">green<span class="gn-deg">°</span></div>
      <p class="hp-foot__blurb">made in cape town from rescued kites, denim, and parachutes. every bag sold funds a filled pencil case for a child at a western cape primary school.</p>
    </div>
    <div class="hp-foot__col">
      <span class="hp-foot__eyebrow">the newsletter</span>
      <div class="hp-foot__nl">
        <input type="email" name="email" placeholder="email" disabled>
        <button aria-label="subscribe" disabled>→</button>
      </div>
      <div class="hp-foot__fine">once a month. no marketing.</div>
    </div>
    <div class="hp-foot__col">
      <span class="hp-foot__eyebrow">articles · social</span>
      <ul class="hp-foot__links">
        <li><a href="/articles">articles</a></li>
        <li><a href="/our-story">our story</a></li>
        <li><a href="https://www.instagram.com/greendegree_/" target="_blank" rel="noopener">instagram</a></li>
        <li><a href="mailto:hello@greendegree.co.za">hello@greendegree.co.za</a></li>
      </ul>
    </div>
  </div>
  <div class="hp-foot__legal">
    <div class="hp-foot__dot" aria-hidden="true"></div>
    <div class="hp-foot__copy">green<span class="gn-deg">°</span> — cape town — founded december 2019 by anne &amp; cheryl.</div>
    <div class="hp-foot__tos-row">
      <a href="#" class="hp-foot__tos">terms</a>
      <span class="hp-foot__sep" aria-hidden="true">·</span>
      <a href="#" class="hp-foot__tos">privacy</a>
    </div>
  </div>
</footer>

</Layout>

<style is:global>
/* ============================================================
   LOADER
   ============================================================ */
.gd-loader {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: opacity 700ms var(--ease-standard);
  pointer-events: all;
}
.gd-loader.is-done {
  opacity: 0;
  pointer-events: none;
}
.gd-loader__brand {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(3rem, 8vw, 6rem);
  letter-spacing: -0.03em;
  color: var(--color-ink);
  line-height: 1;
}
.gd-loader__brand .gn-deg { color: var(--color-lime); }
.gd-loader__rule {
  height: 1px;
  background: var(--color-sage-deep);
  margin-top: 28px;
  width: 0;
  animation: loader-rule 1s cubic-bezier(0.16,1,0.3,1) 400ms forwards;
}
@keyframes loader-rule {
  from { width: 0; }
  to   { width: clamp(80px, 18vw, 200px); }
}

/* ============================================================
   HERO — SCROLL JOURNEY
   ============================================================ */
.hp-hero-outer {
  position: relative;
  height: 280vh;
}
.hp-hero-outer .hp-hero {
  position: sticky;
  top: 0;
  max-height: 100vh;
  height: 100vh;
}
.hp-hero-outer .hp-hero__img {
  transform: scale(1.07);
  will-change: transform;
}
.hp-hero-outer .hp-hero__eyebrow {
  opacity: 0.6;
  transform: translateY(4px);
  will-change: opacity, transform;
}
.hp-hero-outer .hp-hero__title {
  opacity: 0.8;
  transform: translateY(8px);
  will-change: opacity, transform;
}
.hp-hero-outer .hp-hero__caption {
  opacity: 0;
  transform: translateY(16px);
  will-change: opacity, transform;
}
.hp-hero-outer .hp-hero__scroll-cue {
  opacity: 1;
  will-change: opacity;
}
.hp-hero-outer .hp-hero__text {
  will-change: transform;
}

/* ============================================================
   SENTENCE — INTERACTIVE SECTION
   ============================================================ */
.hp-diagram-outer {
  position: relative;
  height: 360vh;
  background: var(--color-bg-tint);
}
.hp-diagram-sticky {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 56px; /* offset for fixed global nav so optical centre sits below it */
}
.hp-diagram-eye {
  position: absolute;
  top: 52px;
  left: 0; right: 0;
  display: flex;
  justify-content: center;
}
.hp-diagram-stage {
  position: relative;
  width: 100%;
  max-width: var(--page-max);
  padding-inline: var(--page-pad);
  display: grid;
  grid-template-columns: 260px 1fr 260px;
  grid-template-rows: auto auto;
  gap: 0 32px;
  align-items: center;
  z-index: 1;
}
.hp-diagram-center {
  grid-column: 2;
  grid-row: 1;
  text-align: center;
  padding: 32px 0;
  will-change: transform;
}
.hp-diagram-sentence {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(2rem, 4.2vw, 3.5rem);
  line-height: 1.15;
  letter-spacing: -0.025em;
  color: var(--color-ink);
  margin: 0;
  text-wrap: balance;
}
.hp-diagram-kw {
  display: inline;
  font: inherit;
  color: inherit;
  background: none;
  border: none;
  border-bottom: 1px solid var(--color-rule);
  cursor: pointer;
  padding: 0;
  transition: color 240ms var(--ease-standard), border-color 240ms var(--ease-standard);
  position: relative;
}
.hp-diagram-kw:hover {
  color: var(--color-sage-deep);
  border-bottom-color: var(--color-sage-deep);
}
.hp-diagram-kw.is-active {
  color: var(--color-sage-deep);
  border-bottom-color: var(--color-sage-deep);
  border-bottom-width: 2px;
}
.hp-diagram-hint {
  font-family: var(--font-ui);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-ink-faint);
  margin-top: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  transition: opacity 400ms;
}
.hp-diagram-hint::before,
.hp-diagram-hint::after {
  content: "";
  display: inline-block;
  width: 20px;
  height: 1px;
  background: currentColor;
  animation: hp-cue 2.4s ease-in-out infinite;
  transform-origin: center;
}
.hp-diagram-hint.is-hidden { opacity: 0; pointer-events: none; }
.hp-diagram-group--left {
  grid-column: 1;
  grid-row: 1;
  text-align: right;
  display: flex;
  flex-direction: column;
  gap: 0;
  align-items: flex-end;
}
.hp-diagram-group--right {
  grid-column: 3;
  grid-row: 1;
  text-align: left;
  display: flex;
  flex-direction: column;
  gap: 0;
  align-items: flex-start;
}
.hp-diagram-group--bottom {
  grid-column: 2;
  grid-row: 2;
  text-align: center;
  display: flex;
  flex-direction: row;
  gap: 40px;
  justify-content: center;
  padding-top: 32px;
}
.hp-diagram-group-label {
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-sage-deep);
  margin-bottom: 16px;
  opacity: 0;
  transition: opacity 300ms var(--ease-standard);
}
.hp-diagram-node {
  font-family: var(--font-ui);
  font-size: 13px;
  line-height: 1.45;
  color: var(--color-ink-soft);
  padding: 10px 0;
  border-bottom: 1px solid var(--color-rule);
  width: 100%;
  opacity: 0;
  transform: translateX(0);
  transition: opacity 360ms var(--ease-out), transform 360ms var(--ease-out);
}
.hp-diagram-group--left .hp-diagram-node {
  transform: translateX(12px);
  text-align: right;
}
.hp-diagram-group--right .hp-diagram-node {
  transform: translateX(-12px);
  text-align: left;
}
.hp-diagram-group--bottom .hp-diagram-node {
  transform: translateY(10px);
  border-bottom: 0;
  border-top: 1px solid var(--color-rule);
  padding-top: 16px;
  max-width: 180px;
  text-align: center;
  font-size: 14px;
}
.hp-diagram-node__num {
  display: block;
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(2rem, 4vw, 2.75rem);
  letter-spacing: -0.04em;
  color: var(--color-ink);
  line-height: 1;
  margin-bottom: 8px;
}
.hp-diagram-group.is-active .hp-diagram-group-label { opacity: 1; }
.hp-diagram-group.is-active .hp-diagram-node {
  opacity: 1;
  transform: translate(0, 0);
}
.hp-diagram-progress-wrap {
  display: none;
  position: absolute;
  bottom: 0;
  left: 0; right: 0;
  height: 2px;
  background: var(--color-rule);
}
.hp-diagram-progress-bar {
  height: 100%;
  width: 0%;
  background: var(--color-sage-deep);
  transition: width 60ms linear;
}
.hp-diagram-dots {
  position: absolute;
  bottom: 28px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  align-items: center;
}
.hp-diagram-dot {
  width: 5px;
  height: 5px;
  border-radius: 999px;
  background: var(--color-rule);
  transition: background 240ms, transform 240ms;
}
.hp-diagram-dot.is-active {
  background: var(--color-sage-deep);
  transform: scale(1.4);
}

/* Word reveal */
.hp-word {
  opacity: 0;
  display: inline-block;
  transform: translateY(8px);
  transition: opacity 600ms var(--ease-out), transform 600ms var(--ease-out);
}
.hp-word.is-revealed { opacity: 1; transform: translateY(0); }
.hp-diagram-kw.hp-word { display: inline-block; vertical-align: baseline; }
.hp-diagram-eye { display: none; }

/* ============================================================
   SENTENCE — MOBILE
   ============================================================ */
@media (max-width: 860px) {
  .hp-diagram-outer { height: 440vh; }
  .hp-diagram-sticky {
    position: sticky !important; top: 0 !important;
    height: 100svh !important; overflow: hidden !important;
    padding: 0 !important; justify-content: flex-start !important;
  }
  .hp-diagram-stage,
  .hp-diagram-dots,
  .hp-diagram-progress-wrap { display: none !important; }
  .hp-diagram-mobile {
    display: flex; flex-direction: column;
    width: 100%; height: 100%; overflow: hidden;
  }
  .hp-mob-sentence-wrap {
    flex-shrink: 0;
    padding: 32px 28px 22px;
    text-align: center;
    border-bottom: 1px solid var(--color-rule);
    will-change: transform;
    transform-origin: top center;
  }
  .hp-mob-sentence-text {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.2rem, 9.5vw, 3.4rem);
    line-height: 1.18;
    letter-spacing: -0.028em;
    color: var(--color-ink);
    text-wrap: balance;
    margin: 0;
  }
  .hp-mob-word { display: inline; }
  .hp-mob-kw {
    display: inline;
    border-bottom: 1px solid transparent;
    transition: color 400ms, border-color 400ms, opacity 520ms;
  }
  .hp-mob-kw.is-kw-active {
    color: var(--color-sage-deep);
    border-bottom-color: var(--color-sage-deep);
  }
  .hp-mob-branch-area { flex: 1; position: relative; overflow: hidden; }
  .hp-mob-branch {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; align-items: center;
    justify-content: center;
    padding: 16px 28px 28px;
    opacity: 0;
    transition: opacity 360ms var(--ease-standard);
    pointer-events: none;
  }
  .hp-mob-branch.is-active { opacity: 1; pointer-events: all; }
  .hp-mob-branch-label {
    font-family: var(--font-ui); font-size: 10px; font-weight: 500;
    letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--color-sage-deep); margin-bottom: 18px; flex-shrink: 0;
    display: flex; align-items: center; gap: 10px;
  }
  .hp-mob-branch-label::before,
  .hp-mob-branch-label::after {
    content: ""; display: inline-block;
    width: 16px; height: 1px; background: var(--color-sage-deep);
  }
  .hp-mob-leaf {
    font-family: var(--font-ui); font-size: 14px; line-height: 1.45;
    color: var(--color-ink-soft);
    padding: 11px 0; border-bottom: 1px solid var(--color-rule);
    width: 100%; text-align: center;
    opacity: 0; transform: translateY(8px);
    transition: opacity 380ms var(--ease-out), transform 380ms var(--ease-out);
  }
  .hp-mob-leaf.is-revealed { opacity: 1; transform: translateY(0); }
  .hp-mob-stat {
    display: block;
    font-family: var(--font-display); font-weight: 300;
    font-size: clamp(2rem, 8vw, 2.75rem); letter-spacing: -0.04em;
    color: var(--color-ink); line-height: 1; margin-bottom: 4px;
  }
  .hp-journey--how .hp-how__head { padding-top: 28px !important; }
}
@media (min-width: 861px) { .hp-diagram-mobile { display: none; } }

/* ============================================================
   IMMERSIVE SCROLL JOURNEY
   ============================================================ */
.hp-journey__dots { display: none; }
.hp-journey--how { background: var(--color-sand); }
.hp-journey--impact { background: var(--color-bg-tint); }
.hp-journey__dot {
  width: 5px; height: 5px;
  border-radius: 999px;
  background: var(--color-rule);
  transition: background 240ms, transform 240ms;
}
.hp-journey__dot.is-active {
  background: var(--color-sage-deep);
  transform: scale(1.5);
}

@media (max-width: 820px) {
  .hp-journey { position: relative; }
  .hp-journey__sticky {
    position: sticky;
    top: 0;
    height: 100svh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    will-change: transform;
  }
  .hp-journey--how .hp-how {
    padding: 0; max-width: 100%; flex: 1;
    display: flex; flex-direction: column; overflow: hidden;
  }
  .hp-journey--how .hp-how__head { padding: 52px 20px 24px; margin-bottom: 0; flex-shrink: 0; }
  .hp-journey--how .hp-how__steps {
    display: flex; flex-direction: row; gap: 24px;
    padding-inline: 20px; overflow: visible; flex: 1;
    align-items: flex-start; will-change: transform; transition: transform 0ms;
  }
  .hp-journey--how .hp-how__step { flex: 0 0 calc(100vw - 40px); max-width: none; overflow-y: auto; }
  .hp-journey--how .hp-how__img-wrap { aspect-ratio: 4/3; }
  .hp-journey--collections .hp-collections {
    padding: 0; max-width: 100%; flex: 1;
    display: flex; flex-direction: column; overflow: hidden;
  }
  .hp-journey--collections .hp-collections__head {
    padding: 52px 20px 20px; margin-bottom: 0;
    flex-direction: column; align-items: flex-start; gap: 12px;
    border-bottom: 1px solid var(--color-rule);
  }
  .hp-journey--collections .hp-collections__shop { display: none; }
  .hp-journey--collections .hp-tiles {
    display: flex; flex-direction: row; gap: 24px;
    padding-inline: 20px; overflow: visible; flex: 1;
    align-items: flex-start; will-change: transform; transition: transform 0ms;
  }
  .hp-journey--collections .hp-tile { flex: 0 0 calc(100vw - 40px); max-width: none; }
  .hp-journey--collections .hp-tile__img-wrap { aspect-ratio: 4/3; }
  .hp-journey__dots {
    display: flex; gap: 8px;
    justify-content: center;
    padding: 16px 20px 20px;
    flex-shrink: 0;
  }
}
@media (min-width: 821px) {
  .hp-journey__sticky { display: contents; }
}

/* ============================================================
   FOUNDERS JOURNEY (mobile)
   ============================================================ */
@media (max-width: 820px) {
  .hp-journey--founders .hp-founders {
    display: flex !important; flex-direction: row;
    padding: 0 !important; padding-inline: 20px !important;
    max-width: 100%; gap: 24px;
    overflow: visible; will-change: transform;
    height: 100%; align-items: flex-start;
  }
  .hp-journey--founders .hp-founders__img-wrap {
    flex: 0 0 calc(100vw - 40px);
    aspect-ratio: 3/4; align-self: center;
  }
  .hp-journey--founders .hp-founders__text {
    flex: 0 0 calc(100vw - 40px);
    max-width: none; padding: 48px 0 40px; overflow-y: auto;
  }
  .hp-journey--founders .hp-reveal {
    opacity: 1 !important; transform: none !important; transition: none !important;
  }
}
@media (min-width: 821px) {
  .hp-journey--founders .hp-journey__dots { display: none !important; }
}

/* ============================================================
   INVITE JOURNEY (mobile)
   ============================================================ */
.hp-invite--photo .hp-invite__scrim {
  background: linear-gradient(180deg,
    rgba(0,0,0,0.55) 0%,
    rgba(0,0,0,0.30) 35%,
    rgba(0,0,0,0.75) 100%);
}
@media (max-width: 820px) {
  .hp-journey--invite .hp-invite { padding: 0; border-top: 0; height: 100%; overflow: hidden; }
  .hp-invite-track { display: flex; flex-direction: row; height: 100%; will-change: transform; }
  .hp-invite-card { flex: 0 0 100vw; height: 100%; overflow: hidden; }
  .hp-invite-card--photo img { width: 100%; height: 100%; object-fit: cover; object-position: center; display: block; }
  .hp-invite-card--text {
    background: var(--color-ink);
    display: flex; flex-direction: column;
    justify-content: flex-end;
    padding: 48px var(--page-pad-mobile) 60px; gap: 28px;
  }
  .hp-invite-card--text .gn-eyebrow { color: rgba(232,225,203,0.6); }
  .hp-invite-card--text .hp-invite__quote {
