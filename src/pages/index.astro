/* ============================================================
   LIME FILLER SCROLL CUE
   ============================================================ */
.hp-lime__cue {
  position: absolute;
  bottom: 28px;
  right: var(--page-pad);
  color: rgba(232, 225, 203, 0.55);
  pointer-events: none;
  opacity: 0;
  transition: opacity 400ms ease;
  z-index: 2;
}
.hp-lime__cue svg {
  animation: hp-cue 2s cubic-bezier(0.45, 0, 0.55, 1) infinite;
}
@media (max-width: 820px) {
  .hp-lime__cue { right: var(--page-pad-mobile); bottom: 80px; }
}
@media (prefers-reduced-motion: reduce) {
  .hp-lime__cue svg { animation: none; }
}

/* ============================================================
   PRODUCT HERO — parallax image
   ============================================================ */
.hp-transition__img {
  transform-origin: center;
  will-change: transform;
}
</style>

<script is:inline>
/* ============================================================
   LOADER
   ============================================================ */
(function () {
  var loader = document.getElementById('gd-loader');
  if (!loader) return;
  setTimeout(function () {
    loader.classList.add('is-done');
    setTimeout(function () { loader.style.display = 'none'; }, 800);
  }, 1400);
})();

/* ============================================================
   HERO SCROLL JOURNEY — text travels full viewport height
   ============================================================ */
(function () {
  var outer   = document.getElementById('hero-outer');
  var img     = outer && outer.querySelector('.hp-hero__img');
  var overlay = outer && outer.querySelector('.hp-hero__overlay');
  var eyebrow = outer && outer.querySelector('.hp-hero__eyebrow');
  var title   = outer && outer.querySelector('.hp-hero__title');
  var cue     = outer && outer.querySelector('.hp-hero__scroll-cue');
  var text    = outer && outer.querySelector('.hp-hero__text');
  if (!outer || !img) return;

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
  function prog(p, a, b)    { return clamp((p - a) / (b - a), 0, 1); }
  function lerp(a, b, t)    { return a + (b - a) * t; }
  function ease(t)           { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

  var cueReady = false;
  setTimeout(function () { cueReady = true; update(); }, 2500);

  function update() {
    var scrollable = outer.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return;
    var p = clamp(-outer.getBoundingClientRect().top / scrollable, 0, 1);

    img.style.transform = 'scale(' + lerp(1.07, 1.0, ease(prog(p, 0, 0.4))) + ')';

    var oa = lerp(0.6, 0.2, ease(prog(p, 0, 0.35)));
    overlay.style.background = 'linear-gradient(180deg,rgba(0,0,0,' + oa + ') 0%,rgba(0,0,0,0) 30%,rgba(0,0,0,0) 55%,rgba(0,0,0,' + (oa + 0.35) + ') 100%)';

    eyebrow.style.opacity   = '1';
    eyebrow.style.transform = 'translateY(0)';
    title.style.opacity   = '1';
    title.style.transform = 'translateY(0)';

    if (cue && cueReady) cue.style.opacity = 1 - ease(prog(p, 0, 0.18));

    if (text) {
      var rp    = ease(prog(p, 0, 1.0));
      var textH = text.offsetHeight;
      text.style.transform = 'translateY(-' + (rp * Math.max(0, window.innerHeight - textH)) + 'px)';
    }
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
})();

/* ============================================================
   SECTION FADE-IN REVEALS
   ============================================================ */
(function () {
  var els = document.querySelectorAll('.hp-reveal');
  if (!els.length) return;
  if (!('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('is-visible'); });
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0, rootMargin: '0px 0px -40px 0px' });
  els.forEach(function (el) { io.observe(el); });
})();

/* ============================================================
   INTERACTIVE SENTENCE — hover reveals (desktop)
   ============================================================ */
(function () {
  if (!window.matchMedia('(min-width: 861px)').matches) return;
  var hint = document.getElementById('diagram-hint');
  var hoveredKey = null;
  var CONFIGS = [
    { key: 'sustainably', kwId: 'dkw-sustainably', grpId: 'dgrp-sustainably' },
    { key: 'raise-funds', kwId: 'dkw-raise-funds', grpId: 'dgrp-raise-funds' },
    { key: 'education',   kwId: 'dkw-education',   grpId: 'dgrp-education'   }
  ];
  function applyState() {
    CONFIGS.forEach(function (cfg) {
      var active = hoveredKey === cfg.key;
      var grp = document.getElementById(cfg.grpId);
      var kw  = document.getElementById(cfg.kwId);
      if (grp) grp.classList.toggle('is-active', active);
      if (kw)  kw.classList.toggle('is-active', active);
    });
    if (hint) hint.classList.toggle('is-hidden', !!hoveredKey);
  }
  CONFIGS.forEach(function (cfg) {
    var kw = document.getElementById(cfg.kwId);
    if (!kw) return;
    kw.addEventListener('mouseenter', function () { hoveredKey = cfg.key; applyState(); });
    kw.addEventListener('mouseleave', function () { hoveredKey = null; applyState(); });
    kw.addEventListener('focus',      function () { hoveredKey = cfg.key; applyState(); });
    kw.addEventListener('blur',       function () { hoveredKey = null; applyState(); });
  });
  applyState();
})();

/* ============================================================
   MOBILE SENTENCE — tap keyword to reveal branch
   ============================================================ */
(function () {
  if (!window.matchMedia('(max-width: 860px)').matches) return;
  var keywords = [
    { kwId: 'mob-sustainably', branchId: 'mob-branch-s', dotIdx: 0 },
    { kwId: 'mob-raise-funds', branchId: 'mob-branch-r', dotIdx: 1 },
    { kwId: 'mob-education',   branchId: 'mob-branch-e', dotIdx: 2 }
  ];
  var dots = document.querySelectorAll('#diagram .hp-diagram-dot');
  var hint = document.getElementById('mob-hint');

  function activate(idx) {
    keywords.forEach(function (cfg, i) {
      var kw = document.getElementById(cfg.kwId);
      var br = document.getElementById(cfg.branchId);
      var active = i === idx;
      if (kw) {
        kw.classList.toggle('is-kw-active', active);
        kw.style.setProperty('--ul', active ? '100%' : '0%');
      }
      if (br) br.classList.toggle('is-active', active);
      if (dots[cfg.dotIdx]) dots[cfg.dotIdx].classList.toggle('is-active', active);
    });
    if (hint) hint.classList.add('is-hidden');
  }

  keywords.forEach(function (cfg, idx) {
    var kw = document.getElementById(cfg.kwId);
    if (kw) kw.addEventListener('click', function () { activate(idx); });
  });
})();

/* ============================================================
   UNIT FILL — lime rises from bottom
   ============================================================ */
(function () {
  var outer   = document.getElementById('unit-outer');
  var fill    = document.getElementById('unit-fill');
  var limeCue = document.getElementById('lime-cue');
  if (!outer || !fill) return;
  function update() {
    var scrollable = outer.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return;
    var p = Math.max(0, Math.min(1, -outer.getBoundingClientRect().top / scrollable));
    fill.style.height = (p * 100) + '%';
    if (limeCue) limeCue.style.opacity = (p > 0.04 && p < 0.94) ? '1' : '0';
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
})();

/* ============================================================
   PRODUCT HERO — parallax zoom on scroll entry
   ============================================================ */
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  var sect = document.querySelector('.hp-transition');
  var img  = sect && sect.querySelector('.hp-transition__img');
  if (!sect || !img) return;
  var raf = null;
  function updateParallax() {
    raf = null;
    var rect = sect.getBoundingClientRect();
    var progress = Math.max(0, Math.min(1, 1 - rect.top / window.innerHeight));
    img.style.transform = 'scale(' + (1.12 - 0.12 * progress) + ')';
  }
  window.addEventListener('scroll', function () {
    if (!raf) raf = requestAnimationFrame(updateParallax);
  }, { passive: true });
  updateParallax();
})();
</script>
