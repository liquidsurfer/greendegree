.hp-press__pub:hover { color: var(--color-ink); }
.hp-press__sep { font-family: var(--font-ui); font-size: 12px; color: var(--color-rule); user-select: none; }
@media (max-width: 640px) {
  .hp-press { padding: 28px 20px; }
  .hp-press__inner { flex-direction: column; align-items: flex-start; gap: 16px; }
  .hp-press__pubs { gap: 0; flex-direction: column; align-items: flex-start; }
  .hp-press__pub { padding: 8px 0; border-bottom: 1px solid var(--color-rule); width: 100%; }
  .hp-press__pub:last-child { border-bottom: 0; }
  .hp-press__sep { display: none; }
}

