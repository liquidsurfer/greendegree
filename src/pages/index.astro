@media (min-width: 821px) { .hp-m-only { display: none !important; } }
@media (max-width: 820px) { .hp-d-only { display: none !important; } }
</style>

<script is:inline>
/* ============================================================
   LOADER
   ============================================================ */
(function () {
  var loader = document.getElementById('gd-loader');
  if (!loader) return;
  setTimeout(function () {
    loader.classList.add('is-done');
    setTimeout(function () { loader.style.display = 'none'; }, 800);
  }, 1400);
})();

/* ============================================================
   HERO SCROLL JOURNEY
   ============================================================ */
(function () {
  var outer   = document.getElementById('hero-outer');
  var img     = outer && outer.querySelector('.hp-hero__img');
  var overlay = outer && outer.querySelector('.hp-hero__overlay');
  var eyebrow = outer && outer.querySelector('.hp-hero__eyebrow');
  var title   = outer && outer.querySelector('.hp-hero__title');
  var cue     = outer && outer.querySelector('.hp-hero__scroll-cue');
  var text    = outer && outer.querySelector('.hp-hero__text');
  if (!outer || !img) return;

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
  function prog(p, a, b)    { return clamp((p - a) / (b - a), 0, 1); }
  function lerp(a, b, t)    { return a + (b - a) * t; }
  function ease(t)           { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

  function update() {
    var scrollable = outer.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return;
    var p = clamp(-outer.getBoundingClientRect().top / scrollable, 0, 1);
    img.style.transform = 'scale(' + lerp(1.07, 1.0, ease(prog(p, 0, 0.4))) + ')';
    var oa = lerp(0.6, 0.2, ease(prog(p, 0, 0.35)));
    overlay.style.background = 'linear-gradient(180deg,rgba(0,0,0,' + oa + ') 0%,rgba(0,0,0,0) 30%,rgba(0,0,0,0) 55%,rgba(0,0,0,' + (oa + 0.35) + ') 100%)';
    var ep = ease(prog(p, 0.28, 0.45));
    eyebrow.style.opacity   = lerp(0.6, 1.0, ep);
    eyebrow.style.transform = 'translateY(' + lerp(4, 0, ep) + 'px)';
    var tp = ease(prog(p, 0.38, 0.58));
    title.style.opacity   = lerp(0.8, 1.0, tp);
    title.style.transform = 'translateY(' + lerp(8, 0, tp) + 'px)';
    if (cue) cue.style.opacity = 1 - ease(prog(p, 0, 0.18));
    if (text) {
      var rp = ease(prog(p, 0.58, 1.0));
      text.style.transform = 'translateY(-' + (rp * window.innerHeight * 0.4) + 'px)';
    }
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
})();

/* ============================================================
   SENTENCE — WORD-BY-WORD REVEAL (desktop)
   ============================================================ */
(function () {
  if (!window.matchMedia('(min-width: 861px)').matches) return;
  var wordThresholds = [
    { id: 'word-we',         threshold: 0.04 },
    { id: 'dkw-sustainably', threshold: 0.10 },
    { id: 'dkw-raise-funds', threshold: 0.38 },
    { id: 'dkw-education',   threshold: 0.60 },
    { id: 'word-insa',       threshold: 0.78 }
  ];
  var outer = document.getElementById('diagram');
  if (!outer) return;
  function update() {
    var scrollable = outer.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return;
    var p = Math.max(0, Math.min(1, -outer.getBoundingClientRect().top / scrollable));
    wordThresholds.forEach(function (cfg) {
      var el = document.getElementById(cfg.id);
      if (el) el.classList.toggle('is-revealed', p >= cfg.threshold);
    });
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
})();

/* ============================================================
   SECTION FADE-IN REVEALS
   ============================================================ */
(function () {
  var els = document.querySelectorAll('.hp-reveal');
  if (!els.length) return;
  if (!('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('is-visible'); });
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.12 });
  els.forEach(function (el) { io.observe(el); });
})();

/* ============================================================
   IMMERSIVE SCROLL JOURNEY (mobile)
   ============================================================ */
(function () {
  var mq = window.matchMedia('(max-width: 820px)');
  if (!mq.matches) return;

  var journeys = [
    { outer: 'journey-how',         track: 'how-track',         cards: 3 },
    { outer: 'journey-collections', track: 'collections-track', cards: 3 },
    { outer: 'founders',            track: 'founders-track',    cards: 2 },
    { outer: 'journey-invite',      track: 'invite-track',      cards: 2, fullScreen: true, endRevealVw: 20 },
    { outer: 'journey-impact',      track: 'impact-track',      cards: 2, fullScreen: true }
  ];

  var exitVh   = 25;  // extra svh of sticky range for hold + lift
  var holdFrac = 0.25; // 25% of exit zone = hold, 75% = lift

  function easeOut3(t) { return 1 - Math.pow(1 - t, 3); }

  journeys.forEach(function (cfg) {
    var outer  = document.getElementById(cfg.outer);
    var track  = document.getElementById(cfg.track);
    if (!outer || !track) return;

    var n      = cfg.cards;
    var dots   = outer.querySelectorAll('.hp-journey__dot');
    var sticky = outer.querySelector('.hp-journey__sticky');
    var totalVh = n * 100 + exitVh;
    outer.style.height = totalVh + 'svh';
    var hEnd = (n * 100) / totalVh; // scroll fraction where horizontal phase ends

    function update() {
      var rect       = outer.getBoundingClientRect();
      var scrollable = outer.offsetHeight - window.innerHeight;
      if (scrollable <= 0) return;
      var progress = Math.max(0, Math.min(1, -rect.top / scrollable));
      var cardW    = cfg.fullScreen ? window.innerWidth : (window.innerWidth - 40 + 24);

      // — Horizontal phase (progress 0 → hEnd) —
      var hProgress = Math.min(progress, hEnd) / hEnd; // 0→1 over horizontal range
      var tx = -hProgress * (n - 1) * cardW;
      if (cfg.endRevealVw) {
        // Cap so endRevealVw% of the previous card stays visible
        var capTx = -((n - 1) * cardW) + (window.innerWidth * cfg.endRevealVw / 100);
        tx = Math.max(tx, capTx);
      }
      track.style.transform = 'translateX(' + tx + 'px)';

      // Dots: lock on final card during exit zone
      var activeIdx = Math.min(n - 1, Math.round(hProgress * (n - 1)));
      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === activeIdx); });

      // — Hold + lift phase (progress hEnd → 1) —
      if (sticky) {
        if (progress > hEnd) {
          var exitP    = (progress - hEnd) / (1 - hEnd); // 0→1 over exit zone
          var liftP    = Math.max(0, (exitP - holdFrac) / (1 - holdFrac));
          var liftPx   = easeOut3(liftP) * window.innerHeight * 1.05;
          sticky.style.transform = 'translateY(-' + liftPx + 'px)';
        } else {
          sticky.style.transform = '';
        }
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  });
})();

/* ============================================================
   MOBILE SENTENCE — word reveal + branches
   ============================================================ */
(function () {
  if (!window.matchMedia('(max-width: 860px)').matches) return;
  var outer = document.getElementById('diagram');
  if (!outer) return;

  var sentenceWrap = outer.querySelector('.hp-mob-sentence-wrap');

  var phases = [
    { start: 0.46, end: 0.64, branchId: 'mob-branch-s', kwId: 'mob-sustainably' },
    { start: 0.66, end: 0.80, branchId: 'mob-branch-r', kwId: 'mob-raise-funds' },
    { start: 0.82, end: 0.96, branchId: 'mob-branch-e', kwId: 'mob-education'   }
  ];

  phases.forEach(function (ph) {
    var branchEl = document.getElementById(ph.branchId);
    if (!branchEl) return;
    var leaves = branchEl.querySelectorAll('.hp-mob-leaf');
    var span   = ph.end - ph.start - 0.04;
    leaves.forEach(function (el, i) {
      el._leafP = ph.start + 0.04 + (i / Math.max(leaves.length, 1)) * span;
    });
  });

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
  function easeOut3(t) { return 1 - Math.pow(1 - t, 3); }

  function getP() {
    var scrollable = outer.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return 0;
    return Math.max(0, Math.min(1, -outer.getBoundingClientRect().top / scrollable));
  }

  function update() {
    var p = getP();
    if (sentenceWrap) {
      var wrapH = sentenceWrap.offsetHeight;
      var vh    = window.innerHeight;
      var centerOffset = Math.max(0, (vh - wrapH) / 2);
      // Hold centred for 0–0.25, lift over 0.25–0.45, settled past 0.45
      var liftP   = easeOut3(clamp((p - 0.25) / 0.20, 0, 1));
      var ty = centerOffset * (1 - liftP);
      var sc = 1 - 0.32 * liftP;
      sentenceWrap.style.transform = 'translateY(' + ty + 'px) scale(' + sc + ')';
    }
    var activeIdx = -1;
    for (var i = phases.length - 1; i >= 0; i--) {
      if (p >= phases[i].start) { activeIdx = i; break; }
    }
    phases.forEach(function (ph, idx) {
      var isActive  = idx === activeIdx;
      var branchEl  = document.getElementById(ph.branchId);
      var kwEl      = document.getElementById(ph.kwId);
      if (branchEl) branchEl.classList.toggle('is-active', isActive);
      if (kwEl)     kwEl.classList.toggle('is-kw-active', isActive);
      if (branchEl) {
        branchEl.querySelectorAll('.hp-mob-leaf').forEach(function (el) {
          el.classList.toggle('is-revealed', isActive && p >= (el._leafP || 1));
        });
      }
    });
  }

  var scheduled = false;
  function schedule() {
    if (scheduled) return;
    scheduled = true;
    window.requestAnimationFrame(function () {
      scheduled = false;
      update();
    });
  }
  window.addEventListener('scroll', schedule, { passive: true });
  window.addEventListener('resize', schedule, { passive: true });
  update();
})();

/* ============================================================
   COUNTER ANIMATION
   ============================================================ */
(function () {
  var nodes = document.querySelectorAll('.hp-counter__num');
  function ease(t) { return 1 - Math.pow(1 - t, 3); }
  function animate(el) {
    if (el.dataset.animated) return;
    el.dataset.animated = '1';
    var target = parseInt(el.dataset.target, 10) || 0;
    var duration = parseInt(el.dataset.duration, 10) || 1800;
    var start = null;
    function frame(ts) {
      if (start === null) start = ts;
      var t = Math.min(1, (ts - start) / duration);
      el.textContent = Math.round(target * ease(t)).toLocaleString('en-US');
      if (t < 1) requestAnimationFrame(frame);
      else el.textContent = target.toLocaleString('en-US');
    }
    requestAnimationFrame(frame);
  }
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { animate(e.target); io.unobserve(e.target); } });
    }, { threshold: 0.35 });
    nodes.forEach(function(n) { io.observe(n); });
  } else { nodes.forEach(animate); }
})();

/* ============================================================
   UNIT FILL — lime rises from bottom
   ============================================================ */
(function () {
  var outer = document.getElementById('unit-outer');
  var fill  = document.getElementById('unit-fill');
  if (!outer || !fill) return;
  function update() {
    var scrollable = outer.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return;
    var p = Math.max(0, Math.min(1, -outer.getBoundingClientRect().top / scrollable));
    fill.style.height = (p * 100) + '%';
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
})();

/* ============================================================
   INTERACTIVE SENTENCE — leaf reveal on scroll (desktop)
   ============================================================ */
(function () {
  if (!window.matchMedia('(min-width: 861px)').matches) return;
  var outer = document.getElementById('diagram');
  var hint  = document.getElementById('diagram-hint');
  if (!outer) return;

  var CONFIGS = [
    { key: 'sustainably', kwId: 'dkw-sustainably', grpId: 'dgrp-sustainably', start: 0.12, end: 0.32 },
    { key: 'raise-funds', kwId: 'dkw-raise-funds', grpId: 'dgrp-raise-funds', start: 0.36, end: 0.56 },
    { key: 'education',   kwId: 'dkw-education',   grpId: 'dgrp-education',   start: 0.60, end: 0.80 }
  ];

  function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

  function getProgress() {
    var scrollable = outer.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return 0;
    return clamp(-outer.getBoundingClientRect().top / scrollable, 0, 1);
  }

  var hoveredKey = null;

  function applyState() {
    var p = getProgress();
    CONFIGS.forEach(function (cfg) {
      var local = clamp((p - cfg.start) / (cfg.end - cfg.start), 0, 1);
      var scrollRevealed = local > 0;
      var active = hoveredKey ? hoveredKey === cfg.key : scrollRevealed;
      var grp = document.getElementById(cfg.grpId);
      var kw  = document.getElementById(cfg.kwId);
      if (grp) grp.classList.toggle('is-active', active);
      if (kw)  kw.classList.toggle('is-active', active);
    });
    if (hint && (getProgress() > 0.05 || hoveredKey)) hint.classList.add('is-hidden');
  }

  CONFIGS.forEach(function (cfg) {
    var kw = document.getElementById(cfg.kwId);
    if (!kw) return;
    kw.addEventListener('mouseenter', function () {
      hoveredKey = cfg.key;
      applyState();
    });
    kw.addEventListener('mouseleave', function () {
      hoveredKey = null;
      applyState();
    });
  });

  var scheduled = false;
  function schedule() {
    if (scheduled) return;
    scheduled = true;
    window.requestAnimationFrame(function () {
      scheduled = false;
      applyState();
    });
  }

  window.addEventListener('scroll', schedule, { passive: true });
  applyState();
})();
</script>
