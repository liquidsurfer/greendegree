  }
  .hp-invite-card--text .hp-invite__cta--ghost {
    background: transparent; color: rgba(232,225,203,0.85);
    border-color: rgba(232,225,203,0.4);
  }
  .hp-journey--invite .hp-journey__dots {
    position: absolute; bottom: 20px; left: 50%;
    transform: translateX(-50%); z-index: 2;
  }
}
@media (min-width: 821px) {
  .hp-journey--invite .hp-journey__dots { display: none !important; }
}

/* ============================================================
   UNIT LIME — sticky fill
   ============================================================ */
.hp-unit-lime {
  background: var(--color-ink);
  padding: 88px 32px;
}
.hp-unit-lime__line {
  font-family: var(--font-display); font-weight: 300;
  font-size: clamp(2.25rem, 6vw, 5rem);
  line-height: 1.05; letter-spacing: -0.028em;
  color: var(--color-bg); margin: 0;
}
.hp-unit-lime__eq { font-style: italic; padding: 0 6px; }
.hp-unit-lime__sub {
  font-family: var(--font-ui); font-size: 13px; font-style: italic;
  color: rgba(232,225,203,0.6); margin: 0; letter-spacing: 0.04em;
}
.hp-unit-lime__cta {
  font-family: var(--font-ui); font-size: 13px; font-weight: 500;
  letter-spacing: 0.04em; text-transform: lowercase;
  padding: 14px 24px; background: var(--color-bg); color: var(--color-ink);
  text-decoration: none; border: none;
  display: inline-flex; align-items: center; gap: 8px;
  margin-top: 20px; align-self: flex-start;
  transition: background 160ms;
}
.hp-unit-lime__cta:hover { background: var(--color-bg-tint); color: var(--color-ink); }
.hp-unit-outer {
  position: relative;
  height: 160vh;
}
.hp-unit-outer .hp-unit-lime {
  position: sticky; top: 0;
  height: 100vh; overflow: hidden;
  display: flex; align-items: flex-start;
  padding: 0;
}
.hp-unit-fill {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 0%;
  background: var(--color-lime);
