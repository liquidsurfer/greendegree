---
import Layout from '../layouts/Layout.astro';
---

<Layout title="articles — green°">

<!-- Header -->
<header class="ar-header">
  <div>
    <span class="gn-eyebrow ar-header__eyebrow">green° in the world</span>
    <h1 class="ar-header__title">articles.</h1>
  </div>
  <p class="ar-header__sub">green° has been featured across South Africa's sustainability, environment and community press. Read the stories behind the story.</p>
</header>

<!-- Articles -->
<main class="ar-grid">

  <a class="ar-article" href="https://greeneconomy.media/parachutes-to-purpose-crafting-change-with-creativity/" target="_blank" rel="noopener">
    <div class="ar-article__meta">
      <span class="ar-article__pub">Green Economy Media</span>
      <span class="ar-article__date">2024</span>
      <span class="ar-article__tag">sustainability</span>
    </div>
    <div class="ar-article__content">
      <h2 class="ar-article__title">Parachutes to Purpose: Crafting Change with Creativity</h2>
      <p class="ar-article__excerpt">How two Cape Town women turned discarded kite sails and denim into a movement — repurposing waste into pencil cases, bags and livelihoods for the Cape Flats.</p>
    </div>
    <span class="ar-article__cta">read article</span>
  </a>

  <a class="ar-article" href="https://www.goodthingsguy.com/environment/parachutes-to-purpose-how-green-degree-is-crafting-change/" target="_blank" rel="noopener">
    <div class="ar-article__meta">
      <span class="ar-article__pub">Good Things Guy</span>
      <span class="ar-article__date">2024</span>
      <span class="ar-article__tag">environment</span>
    </div>
    <div class="ar-article__content">
      <h2 class="ar-article__title">Parachutes to Purpose: How Green Degree is Crafting Change</h2>
      <p class="ar-article__excerpt">The story of green° — from a living room idea to 2,550 children equipped with stationery every year, via recycled kites, donated denim and a sewing café in Masiphumelele.</p>
    </div>
    <span class="ar-article__cta">read article</span>
  </a>

  <a class="ar-article" href="https://twyg.co.za/how-green-degree-supports-education-programmes-through-upcycled-denim/" target="_blank" rel="noopener">
    <div class="ar-article__meta">
      <span class="ar-article__pub">Twyg</span>
      <span class="ar-article__date">2024</span>
      <span class="ar-article__tag">upcycling</span>
    </div>
    <div class="ar-article__content">
      <h2 class="ar-article__title">How Green Degree Supports Education Programmes Through Upcycled Denim</h2>
      <p class="ar-article__excerpt">Twyg explores the green° model: waste fabric in, filled pencil cases out — and how conscious consumerism funds a year's worth of stationery for Western Cape primary school children.</p>
    </div>
    <span class="ar-article__cta">read article</span>
  </a>

</main>

<!-- Footer -->
<footer class="ar-foot">
  <div class="ar-foot__dot" aria-hidden="true"></div>
  <div class="ar-foot__copy">green° — cape town — founded december 2019.</div>
  <a href="/" class="ar-foot__back">← homepage</a>
</footer>

</Layout>

<style>
/* Header */
.ar-header {
  max-width: var(--page-max);
  margin: 0 auto;
  padding: 144px var(--page-pad) 72px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: end;
}
.ar-header__eyebrow { margin-bottom: 24px; }
.ar-header__title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(2.5rem, 6vw, 5.5rem);
  line-height: 0.98;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  margin: 0;
}
.ar-header__sub {
  font-family: var(--font-ui);
  font-size: 16px;
  line-height: 1.7;
  color: var(--color-ink-soft);
  max-width: 36ch;
  align-self: end;
  padding-bottom: 8px;
}
@media (max-width: 720px) {
  .ar-header { padding: 64px var(--page-pad-mobile) 48px; grid-template-columns: 1fr; gap: 24px; }
}

/* Articles grid */
.ar-grid {
  max-width: var(--page-max);
  margin: 0 auto;
  padding: 0 var(--page-pad) 120px;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.ar-article {
  display: grid;
  grid-template-columns: 1fr 2fr auto;
  gap: 32px 48px;
  align-items: start;
  padding: 48px 0;
  border-top: 1px solid var(--color-rule);
  text-decoration: none;
  color: inherit;
  border-bottom: none;
  cursor: pointer;
  position: relative;
}
.ar-article:last-child { border-bottom: 1px solid var(--color-rule); }
.ar-article::after {
  content: "";
  position: absolute;
  inset: 0;
  background: var(--color-bg-tint);
  opacity: 0;
  transition: opacity 200ms;
  z-index: -1;
  margin-inline: -20px;
}
.ar-article:hover::after { opacity: 1; }

.ar-article__meta { display: flex; flex-direction: column; gap: 8px; padding-top: 4px; }
.ar-article__pub {
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-sage-deep);
}
.ar-article__date {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--color-ink-faint);
  letter-spacing: 0.04em;
}
.ar-article__tag {
  display: inline-flex;
  align-items: center;
  font-family: var(--font-ui);
  font-size: 10px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-ink-faint);
  gap: 6px;
  margin-top: 8px;
}
.ar-article__tag::before {
  content: "";
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-lime);
}

.ar-article__content { display: flex; flex-direction: column; gap: 12px; }
.ar-article__title {
  font-family: var(--font-display);
  font-weight: 300;
  font-size: clamp(1.5rem, 2.5vw, 2.25rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--color-ink);
  margin: 0;
  transition: color 200ms;
}
.ar-article:hover .ar-article__title { color: var(--color-sage-deep); }
.ar-article__excerpt {
  font-family: var(--font-ui);
  font-size: 15px;
  line-height: 1.65;
  color: var(--color-ink-soft);
  margin: 0;
  max-width: 54ch;
}

.ar-article__cta {
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: lowercase;
  color: var(--color-ink-soft);
  white-space: nowrap;
  padding-top: 4px;
  display: flex;
  align-items: center;
  gap: 6px;
  transition: color 200ms;
}
.ar-article:hover .ar-article__cta { color: var(--color-ink); }
.ar-article__cta::after { content: "→"; font-size: 14px; }

@media (max-width: 820px) {
  .ar-grid { padding: 0 var(--page-pad-mobile) 80px; }
  .ar-article { grid-template-columns: 1fr; gap: 16px; padding: 36px 0; }
  .ar-article__cta { display: none; }
}

/* Footer */
.ar-foot {
  background: var(--color-bg-tint);
  border-top: 1px solid var(--color-rule);
  padding: 48px var(--page-pad);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24px;
}
.ar-foot__copy {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--color-ink-faint);
  letter-spacing: 0.04em;
}
.ar-foot__dot { width: 5px; height: 5px; border-radius: 50%; background: var(--color-lime); }
.ar-foot__back {
  font-family: var(--font-ui);
  font-size: 12px;
  color: var(--color-ink-soft);
  text-decoration: none;
  border: none;
  letter-spacing: 0.04em;
  transition: color 160ms;
}
.ar-foot__back:hover { color: var(--color-ink); }
@media (max-width: 720px) {
  .ar-foot { padding: 32px var(--page-pad-mobile); flex-direction: column; text-align: center; }
}
</style>
