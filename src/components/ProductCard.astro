---
import type { Product } from '../lib/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const formattedPrice = `R ${product.price.toLocaleString('en-ZA')}`;
const href = `/shop/${product.slug}`;
---

<a class="pc" href={product.slug ? href : undefined}>
  <div class="pc__img-wrap">
    {product.imageUrl ? (
      <img
        class="pc__img"
        src={product.imageUrl}
        alt={product.name}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="pc__img-placeholder">
        <span>{product.name}</span>
      </div>
    )}
    {!product.inStock && (
      <div class="pc__sold-out" aria-label="sold out">sold out</div>
    )}
    <div class="pc__collection">{product.collection}</div>
  </div>

  <div class="pc__body">
    <h2 class="pc__name">{product.name}</h2>
    <p class="pc__materials">{product.colourPattern}{product.materials ? ` · ${product.materials}` : ''}</p>
    <p class="pc__desc">{product.description}</p>
    <div class="pc__footer">
      <span class="pc__price">{formattedPrice}</span>
      {product.inStock ? (
        <span class="pc__cta">view product →</span>
      ) : (
        <span class="pc__cta pc__cta--disabled">sold out</span>
      )}
    </div>
  </div>
</a>

<style>
.pc {
  background: var(--color-bg);
  border: 1px solid var(--color-rule);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 1;
  text-decoration: none;
  color: inherit;
  cursor: pointer;
}

.pc__img-wrap {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  background: var(--color-bg-tint);
}

.pc__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 600ms var(--ease-out);
}

.pc__img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-tint);
  color: var(--color-ink-faint);
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.pc:hover .pc__img {
  transform: scale(1.04);
}

.pc__collection {
  position: absolute;
  top: 16px;
  left: 16px;
  font-family: var(--font-ui);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-sage-deep);
  background: rgba(232, 225, 203, 0.88);
  padding: 4px 10px;
}

.pc__sold-out {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(26, 26, 23, 0.45);
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-bg);
}

.pc__body {
  padding: 24px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  flex: 1;
}

.pc__name {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 400;
  color: var(--color-ink);
  line-height: 1.2;
}

.pc__materials {
  font-size: 12px;
  color: var(--color-ink-faint);
  letter-spacing: 0.04em;
  margin: 0;
}

.pc__desc {
  font-size: 15px;
  color: var(--color-ink-soft);
  line-height: 1.6;
  margin: 0;
  flex: 1;
}

.pc__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8px;
  padding-top: 20px;
  border-top: 1px solid var(--color-rule);
}

.pc__price {
  font-family: var(--font-display);
  font-size: 20px;
  font-weight: 300;
  color: var(--color-ink);
}

.pc__cta {
  font-family: var(--font-ui);
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.04em;
  color: var(--color-sage-deep);
  border-bottom: 1px solid var(--color-sage-deep);
  padding-bottom: 1px;
  transition: color 160ms, border-color 160ms;
}

.pc:hover .pc__cta {
  color: var(--color-ink);
  border-color: var(--color-ink);
}

.pc__cta--disabled {
  color: var(--color-ink-faint);
  border-color: var(--color-ink-faint);
}
</style>
